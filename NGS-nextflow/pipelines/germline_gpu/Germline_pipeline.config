/*
 * Nextflow config for Parabricks GPU variant calling pipeline
 */

// Work directory defaults to execution directory (-w $APP_ROOT)

// — Docker ——————————————————————————————————————————————————————————————————
docker {
    enabled = true

    // ERROR PREVENTION:
    // 1. Double quotes so shell expands $(id -u) and $(id -g) at runtime
    //    (single quotes would pass the literal string, causing permission errors)
    // 2. --runtime=nvidia is MORE RELIABLE than --gpus all for Docker-in-Docker.
    //    --gpus all can silently fail when the inner container is launched via
    //    a mounted Docker socket, because the GPU request doesn't propagate
    //    through the second Docker layer. --runtime=nvidia directly invokes
    //    nvidia-container-runtime, which always works.
    // 3. NVIDIA_VISIBLE_DEVICES=all + NVIDIA_DRIVER_CAPABILITIES=all ensures
    //    the container sees all GPUs with full compute+utility access.
    // 4. --ipc=host is required by Parabricks for shared memory
    // 5. --ulimit memlock=-1 removes memory lock limits
    // 6. --ulimit stack=67108864 sets stack size
    runOptions = "-u \$(id -u):\$(id -g) --runtime=nvidia -e NVIDIA_VISIBLE_DEVICES=all -e NVIDIA_DRIVER_CAPABILITIES=all --ipc=host --ulimit memlock=-1 --ulimit stack=67108864 -e LD_LIBRARY_PATH=/usr/local/nvidia/lib:/usr/local/nvidia/lib64"
}

// — Default resource params ————————————————————————————————————————————————
// These are FALLBACKS only — Germline_pipeline_run.sh calculates and passes
// --fastqc_cpus / --fastqc_mem / etc. dynamically based on actual host
// CPU/RAM. The ?: operator below means: use the CLI-provided value if set,
// otherwise fall back to these defaults (e.g. if running main.nf directly
// without the wrapper script).
params {
    fastqc_cpus = null
    fastqc_mem  = null

    fq2bam_cpus = null
    fq2bam_mem  = null

    hc_cpus = null
    hc_mem  = null

    geno_cpus = null
    geno_mem  = null

    varfilt_cpus = null
    varfilt_mem  = null

    passvcf_cpus = null
    passvcf_mem  = null
}

// — Process defaults ————————————————————————————————————————————————————————
process {
    errorStrategy = 'retry'
    maxRetries    = 1    // reduced to 1 — GPU jobs are expensive, don't retry too many times

    // FastQC — CPU only, no GPU
    withName: 'FASTQC' {
        cpus   = params.fastqc_cpus ?: 4
        memory = params.fastqc_mem  ?: '4 GB'
    }

    // fq2bam — GPU accelerated (replaces BWA_INDEX + BWA_ALIGN + SORT_BAM + MARK_DUPLICATES + INDEX_BAM)
    // ERROR PREVENTION:
    // accelerator directive tells Nextflow to request GPU resources from the scheduler
    // For local Docker executor this works alongside --runtime=nvidia in runOptions above
    withName: 'FQ2BAM' {
        cpus        = params.fq2bam_cpus ?: 8
        memory      = params.fq2bam_mem  ?: '16 GB'
        accelerator = [request: 1]
    }

    withName: 'HAPLOTYPE_CALLER' {
        cpus        = params.hc_cpus ?: 8
        memory      = params.hc_mem  ?: '16 GB'
        accelerator = [request: 1]
    }

    // GenotypeGVCFs — CPU only (does not support --num-gpus)
    withName: 'GENOTYPE_GVCFS' {
        cpus   = params.geno_cpus ?: 4
        memory = params.geno_mem  ?: '8 GB'
    }

    // Variant Filtration — CPU only
    withName: 'VARIANT_FILTRATION' {
        cpus   = params.varfilt_cpus ?: 4
        memory = params.varfilt_mem  ?: '8 GB'
    }
    // Pass VCF
    withName: 'PASS_VCF' {
        cpus   = params.passvcf_cpus ?: 2
        memory = params.passvcf_mem  ?: '4 GB'
    }
}
