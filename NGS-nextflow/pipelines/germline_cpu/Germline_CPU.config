/*
 * Nextflow config for CPU Germline Variant Calling Pipeline
 * (BWA + GATK equivalent of the Parabricks GPU pipeline)
 */

// Work directory defaults to execution directory (-w $APP_ROOT)

// — Docker ——————————————————————————————————————————————————————————————————
docker {
    enabled = true

    // ERROR PREVENTION:
    // Double quotes so shell expands $(id -u) and $(id -g) at runtime
    // (single quotes would pass the literal string, causing permission errors)
    runOptions = "-u \$(id -u):\$(id -g)"
}

// — Default resource params ————————————————————————————————————————————————
// These are FALLBACKS only — Germline_CPU_run.sh calculates and passes
// --fastqc_cpus / --fastqc_mem / etc. dynamically based on actual host
// CPU/RAM. The ?: operator below means: use the CLI-provided value if set,
// otherwise fall back to these defaults (e.g. if running main.nf directly
// without the wrapper script).
params {
    fastqc_cpus = null
    fastqc_mem  = null

    bwa_cpus = null
    bwa_mem  = null

    sort_cpus = null
    sort_mem  = null

    markdup_cpus = null
    markdup_mem  = null

    hc_cpus = null
    hc_mem  = null

    geno_cpus = null
    geno_mem  = null

    varfilt_cpus = null
    varfilt_mem  = null

    passvcf_cpus = null
    passvcf_mem  = null
}

// — Process defaults ————————————————————————————————————————————————————————
process {
    errorStrategy = 'retry'
    maxRetries    = 1

    // FastQC — CPU only
    withName: 'FASTQC' {
        cpus   = params.fastqc_cpus ?: 4
        memory = params.fastqc_mem  ?: '4 GB'
    }

    // BWA alignment
    withName: 'BWA_ALIGN' {
        cpus   = params.bwa_cpus ?: 16
        memory = params.bwa_mem  ?: '16 GB'
    }

    // Sort BAM
    withName: 'SORT_BAM' {
        cpus   = params.sort_cpus ?: 8
        memory = params.sort_mem  ?: '8 GB'
    }

    // Mark duplicates
    withName: 'MARK_DUPLICATES' {
        cpus   = params.markdup_cpus ?: 8
        memory = params.markdup_mem  ?: '8 GB'
    }

    // Index BAM — light task
    withName: 'INDEX_BAM' {
        cpus   = 2
        memory = '2 GB'
    }

    // HaplotypeCaller
    withName: 'HAPLOTYPE_CALLER' {
        cpus   = params.hc_cpus ?: 16
        memory = params.hc_mem  ?: '16 GB'
    }

    // GenotypeGVCFs
    withName: 'GENOTYPE_GVCFS' {
        cpus   = params.geno_cpus ?: 8
        memory = params.geno_mem  ?: '8 GB'
    }

    // Variant Filtration
    withName: 'VARIANT_FILTRATION' {
        cpus   = params.varfilt_cpus ?: 4
        memory = params.varfilt_mem  ?: '8 GB'
    }

    // Pass VCF
    withName: 'PASS_VCF' {
        cpus   = params.passvcf_cpus ?: 2
        memory = params.passvcf_mem  ?: '4 GB'
    }
}

