process {
    withName: FASTQC {
        cpus = 4
        memory = '8 GB'
    }
    withName: FASTP {
        cpus = 8
        memory = '16 GB'
    }
    withName: STAR_INDEX {
        cpus = 16
        memory = '120 GB'
    }
    withName: STAR_ALIGN {
        cpus = 16
        memory = '120 GB'
    }
    withName: FEATURE_COUNTS {
        cpus = 4
        memory = '16 GB'
    }
}

profiles {
    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
    }
}
