/*
 * Nextflow config for Parabricks GPU ChIP-seq pipeline
 */

// — Docker ——————————————————————————————————————————————————————————————————
docker {
    enabled = true

    // ERROR PREVENTION:
    // 1. Double quotes so shell expands $(id -u) and $(id -g) at runtime
    // 2. --runtime=nvidia is MORE RELIABLE than --gpus all for Docker-in-Docker.
    // 3. NVIDIA_VISIBLE_DEVICES=all + NVIDIA_DRIVER_CAPABILITIES=all ensures
    //    the container sees all GPUs with full compute+utility access.
    // 4. --ipc=host is required by Parabricks for shared memory
    // 5. --ulimit memlock=-1 removes memory lock limits
    // 6. --ulimit stack=67108864 sets stack size
    runOptions = "-u \$(id -u):\$(id -g) --runtime=nvidia -e NVIDIA_VISIBLE_DEVICES=all -e NVIDIA_DRIVER_CAPABILITIES=all --ipc=host --ulimit memlock=-1 --ulimit stack=67108864 -e LD_LIBRARY_PATH=/usr/local/nvidia/lib:/usr/local/nvidia/lib64"
}

// — Default resource params ————————————————————————————————————————————————
params {
    fastqc_cpus = null
    fastqc_mem  = null

    fastp_cpus  = null
    fastp_mem   = null

    fq2bam_cpus = null
    fq2bam_mem  = null

    macs2_cpus  = null
    macs2_mem   = null
}

// — Process defaults ————————————————————————————————————————————————————————
process {
    errorStrategy = 'retry'
    maxRetries    = 1

    withName: 'FASTQC' {
        cpus   = params.fastqc_cpus ?: 4
        memory = params.fastqc_mem  ?: '4 GB'
    }

    withName: 'FASTP' {
        cpus   = params.fastp_cpus ?: 4
        memory = params.fastp_mem  ?: '8 GB'
    }

    // fq2bam — GPU accelerated alignment
    withName: 'FQ2BAM' {
        cpus        = params.fq2bam_cpus ?: 8
        memory      = params.fq2bam_mem  ?: '16 GB'
        accelerator = [request: 1]
    }

    withName: 'MACS2' {
        cpus   = params.macs2_cpus ?: 4
        memory = params.macs2_mem  ?: '8 GB'
    }
}
